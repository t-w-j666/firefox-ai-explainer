{
  "manifest_version": 3,
  "name": "AI Text Explainer",
  "version": "1.0.1",
  "description": "划选网页文本，直接调用大模型 API 以 SSE 流式获取 LLM 解释（Lexical Approach）。无需启动 Python 后端。",

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Text Explainer"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ai-text-explainer@local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "permissions": ["storage"],

  "background": {
    "scripts": ["background.js"]
  },

  "host_permissions": [
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": ["popup.css"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
